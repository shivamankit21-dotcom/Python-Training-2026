import random
num = random.randint(1, 10)
attempts = []
while True:
    guess = int(input("Guess a number (1-10): "))
    attempts.append(guess)
    if guess < num:
        print("Too Low")
    elif guess > num:
        print("Too High")
    else:
        print("Correct Guess!")
        break
print("Number of Attempts:", len(attempts[:]))


