import random
import string

while True:
    print("\n1. Generate Password  2. Validate Password  3. Exit")
    choice = input("Choose an option: ").strip()

    if choice == "1":
        
        length_input = input("Enter length (default 12): ").strip()
        length = int(length_input) if length_input else 12
        
        pool = string.ascii_letters + string.digits + string.punctuation
        
        password = "".join(random.choice(pool) for _ in range(length))
        print(f" Generated Password: {password}")

    elif choice == "2":
        password = input("Enter password to validate: ")
   
        if len(password) < 8:
            print(" Invalid: Must be at least 8 characters long.")
        elif not any(char.isupper() for char in password):
            print(" Invalid: Must contain an uppercase letter (A-Z).")
        elif not any(char.islower() for char in password):
            print(" Invalid: Must contain a lowercase letter (a-z).")
        elif not any(char.isdigit() for char in password):
            print(" Invalid: Must contain a number (0-9).")
        elif not any(char in string.punctuation for char in password):
            print(" Invalid: Must contain a special character.")
        else:
            print("Valid: Strong password!")

    elif choice == "3":
        print("Goodbye!")
        break
